<odoo>
    <record id="view_account_payment_register_form" model="ir.ui.view">
        <field name="name">account.payment.register.form.inherit.wallet</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group2']" position="after">
                <group name="group_extend" />
                <group name="group_wallet"
                    invisible="payment_difference == 0.0 or payment_difference_handling != 'open' or not can_edit_wizard or can_group_payments and not group_payment">
                    <field name="is_wallet" />
                    <field name="wallet_type_id"
                        invisible="not is_wallet"
                        required="is_wallet" />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
