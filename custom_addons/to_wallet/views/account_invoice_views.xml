<odoo>
    <record id="view_move_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit.wallet</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']/list" position="inside">
                <field name="wallet_id" optional="hide" readonly="1" />
                <field name="wallet_amount_currency" optional="hide" groups="base.group_multi_currency" />
                <field name="non_wallet_amount_currency" optional="hide" readonly="1" groups="base.group_multi_currency" />
            </xpath>
            <xpath expr="//field[@name='line_ids']/form/group[./field[@name='credit']]" position="after">
                <group groups="to_wallet.group_wallet_manager">
                    <field name="wallet_id" readonly="1" />
                    <field name="wallet_amount_currency" groups="base.group_multi_currency" />
                    <field name="non_wallet_amount_currency" readonly="1" groups="base.group_multi_currency" />
                </group>
            </xpath>
            <xpath expr="//button[@name='action_register_payment']" position="after">
                <button name="action_register_payment_by_wallet" type="object" class="btn-primary"
                    string="Register Payment By Wallet" groups="account.group_account_invoice"
                    invisible="state != 'posted' or payment_state not in ('not_paid', 'partial') or move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')" />
            </xpath>
        </field>
    </record>
</odoo>
