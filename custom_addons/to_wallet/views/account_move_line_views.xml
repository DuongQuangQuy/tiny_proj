<odoo>

	<record id="view_move_line_list" model="ir.ui.view">
		<field name="name">account.move.line.list</field>
		<field name="model">account.move.line</field>
		<field name="inherit_id" ref="account.view_move_line_tree" />
		<field name="arch" type="xml">
			<xpath expr="//field[@name='date_maturity']" position="after">
				<field name="wallet_id" optional="hide" />
				<field name="wallet_amount_currency"  optional="hide" groups="base.group_multi_currency" />
				<field name="non_wallet_amount_currency" optional="hide" groups="base.group_multi_currency" />
				<field name="wallet_amount_residual_currency" optional="hide" groups="base.group_multi_currency" />
				<field name="non_wallet_amount_residual_currency" optional="hide" groups="base.group_multi_currency" />
			</xpath>
		</field>
	</record>

	<record id="view_move_line_form" model="ir.ui.view">
		<field name="name">account.move.line.form</field>
		<field name="model">account.move.line</field>
		<field name="inherit_id" ref="account.view_move_line_form" />
		<field name="arch" type="xml">
			<xpath expr="//group[./field[@name='analytic_distribution']]" position="after">
				<group string="eWallet" groups="to_wallet.group_wallet_manager">
					<field name="wallet_id" readonly="1" />
					<field name="wallet_amount_currency" groups="base.group_multi_currency" />
					<field name="non_wallet_amount_currency" readonly="1" groups="base.group_multi_currency" />
				</group>
			</xpath>
		</field>
	</record>

</odoo>
