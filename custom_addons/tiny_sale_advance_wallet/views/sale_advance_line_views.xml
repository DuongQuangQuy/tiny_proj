<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Tree view for sale.advance.line inline -->
    <record id="view_sale_advance_line_tree" model="ir.ui.view">
        <field name="name">sale.advance.line.tree</field>
        <field name="model">sale.advance.line</field>
        <field name="arch" type="xml">
            <list string="Advance Lines" create="0" delete="0" editable="bottom">
                <field name="date"/>
                <field name="advance_type"/>
                <field name="transaction_type"/>
                <field name="payment_id" optional="show"/>
                <field name="wallet_history_id" optional="show"/>
                <field name="currency_id" invisible="1"/>
                <field name="amount" sum="Total"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Inherit sale.order form: thêm tab advance lines + override tab Payment advances -->
    <record id="view_sale_order_form_advance_wallet" model="ir.ui.view">
        <field name="name">sale.order.form.advance.wallet</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_advance_payment.view_order_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Các khoản đặt cọc" groups="account.group_account_invoice">
                    <field
                        name="advance_line_ids"
                        nolabel="1"
                        colspan="4"
                        readonly="1"
                        context="{'tree_view_ref': 'tiny_sale_advance_wallet.view_sale_advance_line_tree'}"
                    />
                </page>
            </notebook>
        </field>
    </record>
</odoo>
