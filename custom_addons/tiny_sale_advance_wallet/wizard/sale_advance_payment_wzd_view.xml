<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_voucher_wizard_wallet" model="ir.ui.view">
        <field name="name">account.voucher.wizard.wallet</field>
        <field name="model">account.voucher.wizard</field>
        <field name="inherit_id" ref="sale_advance_payment.view_account_voucher_wizard"/>
        <field name="arch" type="xml">
            <!-- Thêm is_wallet sau payment_type -->
            <field name="payment_type" position="after">
                <field name="is_wallet"/>
                <field
                    name="wallet_type_id"
                    invisible="not is_wallet"
                    required="is_wallet"
                />
                <field
                    name="wallet_id"
                    invisible="not is_wallet"
                    required="is_wallet"
                    options="{'no_create': True}"
                />
            </field>
            <!-- Ẩn journal_id khi is_wallet, thay domain -->
            <field name="journal_id" position="replace">
                <field
                    name="journal_id"
                    widget="selection"
                    string="Payment Method"
                    domain="[('type', 'in', ['bank', 'cash'])]"
                    invisible="is_wallet"
                    required="not is_wallet"
                />

                <field
                    name="journal_id"
                    widget="selection"
                    string="Payment Method"
                    domain="[('type', 'in', ['general'])]"
                    invisible="not is_wallet"
                    required="is_wallet"
                />
            </field>
            <!-- Ẩn currency fields khi is_wallet -->
            <field name="journal_currency_id" position="attributes">
                <attribute name="invisible">is_wallet</attribute>
            </field>
        </field>
    </record>
</odoo>
