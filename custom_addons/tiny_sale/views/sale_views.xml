<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_sale_order_form_inherit" model="ir.ui.view">
        <field name="model">sale.order</field>
        <field name="name">view.sale.order.form.inherit</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="before" >
                <field name="product_size" />
                <field name="note" />
                <field name="default_code" />
                <field name="product_pattern_id" />
                <field name="product_pattern_image" widget="image" class="oe_avatar w-auto float-start" force_save="1" readonly="1"/>
                <field name="note_pattern" />
            </xpath>

        </field>
    </record>
</odoo>