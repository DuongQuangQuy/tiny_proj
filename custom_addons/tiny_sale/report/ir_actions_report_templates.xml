<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_saleorder_document" inherit_id="sale.report_saleorder_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="replace">
           <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
           <meta charset="UTF-8"/>
           <style>
               /* Background cho toàn bộ trang */
               body {
                   background-color: #F5F5F0 !important;
                   margin: 0 !important;
                   padding: 0 !important;
                   font-family: 'Times New Roman', Times, serif !important;
                   font-weight: normal !important;
               }
               @page {
                   background-color: #F5F5F0;
                   margin: 0;
               }
               /* Padding để tạo lề */
               .page {
                   padding-top: 10mm !important;
                   padding-bottom: 10mm !important;
                   padding-left: 7mm !important;
                   padding-right: 7mm !important;
                   background-color: #F5F5F0;
                   font-family: 'Times New Roman', Times, serif !important;
                   font-weight: normal !important;
               }
               /* Fix font cho tiếng Việt - không bold */
               * {
                   font-family: 'Times New Roman', Times, serif !important;
                   font-weight: normal !important;
               }
               /* Giữ bold cho thẻ strong và b */
               strong, b {
                   font-weight: bold !important;
               }
           </style>
        
        <div class="page" style="font-family: 'Times New Roman', Times, serif; font-size: 10pt; font-weight: normal;">
                    
                    <!-- Header Section -->
                    <div style="margin-bottom: 20px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 30%; vertical-align: top;">
                                    <!-- Logo -->
                                    <div style="font-size: 32pt; font-weight: bold; color: #000; line-height: 1; letter-spacing: 2px;">
                                        TINY INK
                                    </div>
                                    <div style="font-size: 7pt; margin-top: 5px; font-weight: bold; letter-spacing: 0.5px;">
                                        WEARABLE ART TAILORED FOR EXCLUSIVE SOUL
                                    </div>
                                </td>
                                <td style="width: 35%; vertical-align: top; padding-left: 20px;">
                                    <div style="font-size: 8pt; line-height: 1.6;">
                                        <div>11E Phan Kế Bính, Tân Định,</div>
                                        <div>Hồ Chí Minh, 700000</div>
                                        <div>Vietnam</div>
                                        <div>customercare@tinyink.com.vn</div>
                                        <div>+84 92 999 6228</div>
                                    </div>
                                </td>
                                <td style="width: 35%; vertical-align: top; padding-left: 20px;">
                                    <table style="width: 100%; border-collapse: collapse; font-size: 9pt;">
                                        <tr>
                                            <td style="padding: 5px 8px; font-weight: bold; text-align: left;">NO.</td>
                                            <td style="padding: 5px 8px; text-align: right;" t-esc="doc.name"></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 5px 8px; font-weight: bold; font-style: italic; text-align: left;">Order Date</td>
                                            <td style="padding: 5px 8px; text-align: right;" t-esc="doc.date_order.strftime('%d/%m/%Y') if doc.date_order else ''"></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 5px 8px; font-weight: bold; font-style: italic; text-align: left;">Delivery Date</td>
                                            <td style="padding: 5px 8px; text-align: right;" t-esc="doc.commitment_date.strftime('%d/%m/%Y') if doc.commitment_date else ''"></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 5px 8px; font-weight: bold; font-style: italic; text-align: left;">Giao hàng</td>
                                            <td style="padding: 5px 8px; text-align: right;" t-esc="doc.commitment_date.strftime('%d/%m/%Y') if doc.commitment_date else ''"></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
                    </div>

                        <!-- Bill To & Ship To Section -->
                        <div style="margin-bottom: 20px;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 9pt;">
                                <tr>
                                    <td style="width: 50%; vertical-align: top; padding-right: 10px;">
                                        <div style="margin-bottom: 5px;">
                                            <strong>Bill To</strong>
                                            <span style="border-bottom: 1px dotted #000; display: inline-block; min-width: 200px; margin-left: 10px;">
                                                <t t-esc="doc.partner_id.code"/>
                                            </span>
                                        </div>

                                        <div style="margin-bottom: 5px;">
                                            <strong>Khách hàng</strong>
                                            <span style="border-bottom: 1px dotted #000; display: inline-block; min-width: 200px; margin-left: 10px;">
                                                <t t-esc="doc.partner_id.name">Khách hàng</t>
                                            </span>
                                        </div>
                                        <div style="margin-bottom: 5px;">
                                            <strong>Địa chỉ</strong>
                                            <span style="border-bottom: 1px dotted #000; display: inline-block; min-width: 200px; margin-left: 10px;">
                                                <t t-esc="doc.partner_id.street or ''"></t>
                                            </span>
                                        </div>
                                        <div style="margin-bottom: 5px;">
                                            <strong>Điện thoại</strong>
                                            <span style="border-bottom: 1px dotted #000; display: inline-block; min-width: 200px; margin-left: 10px;">
                                                <t t-esc="doc.partner_id.phone or doc.partner_id.mobile or ''"></t>
                                            </span>
                                        </div>
                                    </td>
                                    <td style="width: 50%; vertical-align: top; padding-left: 10px;">

                                        <div style="margin-bottom: 5px;">
                                            <strong>Cửa hàng</strong>
                                            <span style="border-bottom: 1px dotted #000; display: inline-block; min-width: 200px; margin-left: 10px;">
                                                <t t-esc="doc.partner_shipping_id.name if doc.partner_shipping_id != doc.partner_id else doc.partner_id.name"></t>
                                            </span>
                                        </div>

                                        <div style="margin-bottom: 5px;">
                                            <strong>Khách hàng</strong>
                                            <span style="border-bottom: 1px dotted #000; display: inline-block; min-width: 200px; margin-left: 10px;">
                                                <t t-esc="doc.partner_shipping_id.name if doc.partner_shipping_id != doc.partner_id else doc.partner_id.name"></t>
                                            </span>
                                        </div>
                                        <div style="margin-bottom: 5px;">
                                            <strong>Địa chỉ</strong>
                                            <span style="border-bottom: 1px dotted #000; display: inline-block; min-width: 200px; margin-left: 10px;">
                                                <t t-esc="doc.partner_shipping_id.street if doc.partner_shipping_id != doc.partner_id else doc.partner_id.street or ''"></t>
                                            </span>
                                        </div>
                                        <div style="margin-bottom: 5px;">
                                            <strong>Điện thoại</strong>
                                            <span style="border-bottom: 1px dotted #000; display: inline-block; min-width: 200px; margin-left: 10px;">
                                                <t t-esc="doc.partner_shipping_id.phone if doc.partner_shipping_id != doc.partner_id else doc.partner_id.phone or doc.partner_id.mobile or ''"></t>
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Product Table -->
                        <div style="margin-bottom: 20px;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 8pt;">
                                <thead>
                                    <tr style="background-color: #17a2b8; color: white; font-weight: bold;">
                                        <th style="border: 1px solid #fff; padding: 8px; text-align: center; width: 3%; background-color: #17a2b8;">No.</th>
                                        <th style="border: 1px solid #fff; padding: 8px; text-align: center; width: 15%; background-color: #17a2b8;">MÃ SP</th>
                                        <th style="border: 1px solid #fff; padding: 8px; text-align: center; width: 8%; background-color: #17a2b8;">HÌNH SP</th>
                                        <th style="border: 1px solid #fff; padding: 8px; text-align: center; width: 10%; background-color: #17a2b8;">SỐ ĐO</th>
                                        <th style="border: 1px solid #fff; padding: 8px; text-align: center; width: 15%; background-color: #17a2b8;">GHI CHÚ</th>
                                        <th style="border: 1px solid #fff; padding: 8px; text-align: center; width: 10%; background-color: #17a2b8;">MÃ VẢI</th>
                                        <th style="border: 1px solid #fff; padding: 8px; text-align: center; width: 10%; background-color: #17a2b8;">MÃ HOA TIẾT</th>
                                        <th style="border: 1px solid #fff; padding: 8px; text-align: center; width: 8%; background-color: #17a2b8;">HÌNH HOA TIẾT</th>
                                        <th style="border: 1px solid #fff; padding: 8px; text-align: center; width: 10%; background-color: #17a2b8;">GIÁ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="line_num" t-value="0"/>
                                    <t t-foreach="doc.order_line.filtered(lambda l: not l.display_type)" t-as="line">
                                        <t t-set="line_num" t-value="line_num + 1"/>
                                        <tr>
                                            <!-- No. -->
                                            <td style="border: 1px solid #ddd; padding: 8px; text-align: center; vertical-align: top;">
                                                <span t-esc="line_num">01</span>
                                            </td>
                                            <!-- Mã SP -->
                                            <td style="border: 1px solid #ddd; padding: 8px; vertical-align: top;">
                                                <span t-esc="line.product_id.name or ''">Product Name</span>
                                            </td>
                                            <!-- HÌNH SP -->
                                            <td style="border: 1px solid #ddd; padding: 8px; text-align: center; vertical-align: top;">
                                                <t t-if="line.image_128">
                                                    <img t-att-src="image_data_uri(line.image_128)" style="max-width: 60px; max-height: 80px;"/>
                                                </t>
                                            </td>
                                            <!-- SỐ ĐO -->
                                            <td style="border: 1px solid #ddd; padding: 8px; vertical-align: top; font-size: 8pt;">
                                                <span t-esc="line.product_size or ''"></span>
                                            </td>
                                            <!-- GHI CHÚ -->
                                            <td style="border: 1px solid #ddd; padding: 8px; vertical-align: top; font-size: 8pt;">
                                                <span t-esc="line.note or ''"></span>
                                            </td>
                                            <!-- MÃ VẢI -->
                                            <td style="border: 1px solid #ddd; padding: 8px; text-align: center; vertical-align: top;">
                                                <span t-esc="line.default_code or ''"></span>
                                            </td>
                                            <!-- MÃ HOA TIẾT -->
                                            <td style="border: 1px solid #ddd; padding: 8px; text-align: center; vertical-align: top;">
                                                <span t-esc="line.product_pattern_id.name if line.product_pattern_id else ''"></span>
                                            </td>
                                            <!-- HÌNH HOA TIẾT -->
                                            <td style="border: 1px solid #ddd; padding: 8px; text-align: center; vertical-align: top;">
                                                <t t-if="line.product_pattern_image">
                                                    <img t-att-src="image_data_uri(line.product_pattern_image)" style="max-width: 50px; max-height: 50px;"/>
                                                </t>
                                            </td>
                                            <!-- GIÁ -->
                                            <td style="border: 1px solid #ddd; padding: 8px; text-align: right; vertical-align: top;">
                                                <span t-esc="'{:,.0f}'.format(line.price_unit)">0</span>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Note Section -->
                        <div style="margin-bottom: 15px; font-size: 8pt; font-style: italic;">
                            *** Vui lòng đóng mẫu trong vòng 2 tháng kể từ ngày xác nhận hoàn thiện
                        </div>

                        <!-- Footer Section -->
                        <div style="margin-top: 20px;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 9pt;">
                                <tr>
                                    <td style="width: 50%; vertical-align: top; padding-right: 10px;">
                                        <!-- Payment Method -->
                                        <div style="font-weight: bold; color: #17a2b8; margin-bottom: 10px; font-size: 11pt;">
                                            PHƯƠNG THỨC THANH TOÁN
                                        </div>
                                        <div style="margin-bottom: 10px;">
                                            <div style="margin-bottom: 5px;">* Quét mã QR để thanh toán</div>
                                            <div style=" padding: 10px; display: inline-block;">
                                                <!-- TODO: Thêm field qr_code_image -->
                                                <div style="width: 100px; height: 100px; background-color: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 8pt; color: #999;">
                                                    QR Code
                                                </div>
                                            </div>
                                        </div>
                                        <div style="margin-top: 15px;">
                                            <div style="font-weight: bold; margin-bottom: 5px;">* Hoặc chuyển khoản theo thông tin dưới đây</div>
                                            <table style="width: 100%; font-size: 8pt; line-height: 1.8;">
                                                <tr>
                                                    <td style="width: 30%;"><strong>Số TK</strong></td>
                                                    <td>
                                                        <!-- TODO: Thêm field bank_account_number -->
                                                        <span style="color: #999;"></span>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td><strong>Chủ TK</strong></td>
                                                    <td>
                                                        <!-- TODO: Thêm field bank_account_name -->
                                                        <span style="color: #999;"></span>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td style="vertical-align: top;"><strong>Ngân hàng</strong></td>
                                                    <td>
                                                        <!-- TODO: Thêm field bank_name -->
                                                        <span style="color: #999;"></span>
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                    </td>
                                    <td style="width: 50%; vertical-align: top; padding-left: 10px;">
                                        <!-- Total Information -->
                                        <div style="font-weight: bold; margin-bottom: 10px; text-align: right;">Thông tin</div>
                                        <table style="width: 100%; font-size: 9pt; margin-bottom: 15px;">
                                            <tr>
                                                <td style="padding: 5px;"><strong>Sản phẩm riêng</strong></td>
                                                <td style="text-align: right; padding: 5px;">
                                                    <!-- TODO: Thêm field is_custom_product -->
                                                    <span style="color: #999;">-</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 5px;"><strong>Đặt cọc</strong></td>
                                                <td style="text-align: right; padding: 5px;">
                                                    <t t-set="deposit_amount" t-value="doc.amount_total - (doc.amount_residual or doc.amount_total)"/>
                                                    <span t-esc="'{:,.0f}'.format(deposit_amount)">0</span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 5px;  font-weight: bold;">Còn lại</td>
                                                <td style="padding: 5px;  text-align: right; font-weight: bold;">
                                                    <span t-esc="'{:,.0f}'.format(doc.amount_residual or doc.amount_total)">0</span>
                                                </td>
                                            </tr>
                                        </table>
                                        <div style="margin-top: 30px; text-align: center;">
                                            <div style="font-weight: bold; margin-bottom: 50px;">Khách hàng</div>
                                            <div style="border-bottom: 1px dotted #000; width: 200px; margin: 0 auto;"></div>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Legal Notice -->
                        <div style="margin-top: 20px; font-size: 7pt; font-style: italic; text-align: justify; line-height: 1.4;">
                            Hành trình may đo của bạn cùng <strong>Tiny Ink</strong> bắt đầu từ đây. Chúng tôi tâm trong hành trình này và sẽ làm nên những thiết kế mang chữ ký 
                            phong cách riêng của bạn. Cảm ơn bạn đã sử dụng hành cùng <strong>Tiny Ink</strong>.
                        </div>

                        <!-- Footer Brand -->
                        <div style="margin-top: 30px; text-align: center; font-weight: bold; font-size: 10pt; padding: 10px 0; border-top: 2px solid #17a2b8;">
                            TINYINK.VN
                        </div>

        </div>
        </xpath>
    </template>

</odoo>
