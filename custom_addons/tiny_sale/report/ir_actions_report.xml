<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Paperformat riêng cho TINY INK - loại bỏ header margin -->
    <record id="paperformat_tiny_sale" model="report.paperformat">
        <field name="name">TINY INK Sale Order</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Override report action để dùng paperformat mới -->
    <record id="sale.action_report_saleorder" model="ir.actions.report">
        <field name="paperformat_id" ref="paperformat_tiny_sale"/>
    </record>

    <record id="sale_pdf_quote_builder.action_report_saleorder_raw" model="ir.actions.report">
        <field name="paperformat_id" ref="paperformat_tiny_sale"/>
    </record>
</odoo>
