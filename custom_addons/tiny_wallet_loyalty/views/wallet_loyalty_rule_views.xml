<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wallet_loyalty_rule_form" model="ir.ui.view">
        <field name="name">wallet.loyalty.rule.form</field>
        <field name="model">wallet.loyalty.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Top-Up 500k Get 50k Bonus"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Configuration">
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="currency_id" options="{'no_create': True}"/>
                            <field name="wallet_type_id" options="{'no_create': True}"
                                placeholder="All wallet types"/>
                            <field name="reward_wallet_type_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Condition">
                            <field name="min_amount"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group string="Reward">
                        <group>
                            <field name="reward_type"/>
                            <field name="reward_value" string="Reward Amount"
                                invisible="reward_type != 'fixed'"/>
                            <field name="reward_value" string="Reward Percentage (%)"
                                invisible="reward_type != 'percent'"/>
                            <field name="max_reward_amount" invisible="reward_type != 'percent'"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" nolabel="1" placeholder="Description..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="wallet_loyalty_rule_list" model="ir.ui.view">
        <field name="name">wallet.loyalty.rule.list</field>
        <field name="model">wallet.loyalty.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="wallet_type_id"/>
                <field name="reward_wallet_type_id"/>
                <field name="min_amount"/>
                <field name="currency_id" groups="base.group_multi_currency"/>
                <field name="reward_type"/>
                <field name="reward_value" string="Reward Value"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="wallet_loyalty_rule_search" model="ir.ui.view">
        <field name="name">wallet.loyalty.rule.search</field>
        <field name="model">wallet.loyalty.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="wallet_type_id"/>
                <field name="reward_wallet_type_id"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="fixed" string="Fixed Amount" domain="[('reward_type', '=', 'fixed')]"/>
                <filter name="percent" string="Percentage" domain="[('reward_type', '=', 'percent')]"/>
            </search>
        </field>
    </record>

    <record id="action_wallet_loyalty_rules" model="ir.actions.act_window">
        <field name="name">Loyalty Rules</field>
        <field name="res_model">wallet.loyalty.rule</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <menuitem id="menu_wallet_loyalty_rules"
        name="Loyalty Rules"
        parent="account.menu_finance_receivables"
        action="action_wallet_loyalty_rules"
        sequence="21"/>

</odoo>
