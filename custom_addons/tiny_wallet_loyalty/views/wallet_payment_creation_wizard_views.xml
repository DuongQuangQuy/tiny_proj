<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wallet_payment_creation_wizard_form_loyalty" model="ir.ui.view">
        <field name="name">wallet.payment.creation.wizard.form.loyalty</field>
        <field name="model">wallet.payment.creation.wizard</field>
        <field name="inherit_id" ref="to_wallet.wallet_payment_creation_wizard_form_views"/>
        <field name="arch" type="xml">
            <field name="payment_ref" position="after">
                <field name="loyalty_rule_id"
                    string="Loyalty Promotion"
                    invisible="type != 'inbound'"
                    options="{'no_create': True}"
                    domain="[
                        ('active', '=', True),
                        ('currency_id', '=', currency_id),
                        ('min_amount', '&lt;=', amount),
                        '|', ('company_id', '=', False), ('company_id', '=', company_id),
                        '|', ('wallet_type_id', '=', False), ('wallet_type_id', '=', wallet_type_id),
                        '|', ('date_from', '=', False), ('date_from', '&lt;=', context_today()),
                        '|', ('date_to', '=', False), ('date_to', '&gt;=', context_today()),
                    ]"
                />
                <field name="loyalty_bonus_amount"
                    string="Estimated Bonus"
                    invisible="not loyalty_rule_id or type != 'inbound'"
                    readonly="1"/>
            </field>
        </field>
    </record>

</odoo>
