<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mrp_workorder_tree_editable_view_mo_form_inherit" model="ir.ui.view">
        <field name="model">mrp.workorder</field>
        <field name="name">view.mrp.workorder.tree.editable.view.mo.form.inherit</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_editable_view_mo_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='qty_remaining']" position="after" >
                <field name="user_mrp_ids" widget="many2many_tags"/>
            </xpath>

        </field>
    </record>

    <record id="view_mrp_workorder_form_view_inherit" model="ir.ui.view">
        <field name="model">mrp.workorder</field>
        <field name="name">view.mrp.workorder.form.view.inherit</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='loss_id']" position="after" >
                <field name="user_mrp_id" />
            </xpath>
            <xpath expr="//page[@ name='dependencies']" position="after" >
                <page name="reason" string="Lý do">
                    <field name="reason_ids">
                        <list>
                            <field name="user_id"/>
                            <field name="name"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>