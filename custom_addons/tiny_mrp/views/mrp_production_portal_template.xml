<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ===================== PORTAL HOME ENTRY ===================== -->
    <template id="portal_my_home_production" inherit_id="portal.portal_my_home"
              customize_show="True" name="Lệnh Sản Xuất MRP">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Lệnh Sản Xuất</t>
                <t t-set="url" t-value="'/my/productions'"/>
                <t t-set="count" t-value="production_count"/>
                <t t-set="placeholder_count">lệnh</t>
            </t>
        </xpath>
    </template>

    <!-- ===================== PRODUCTION LIST ===================== -->
    <template id="portal_my_productions" name="My Productions">
        <t t-call="portal.portal_layout">
            <div class="o_portal_my_productions">
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Lệnh Sản Xuất Chờ Xác Nhận</t>
            </t>
            <t t-if="not productions">
                <div class="alert alert-info mt-4" role="alert">
                    <i class="fa fa-info-circle me-1"/>
                    Bạn chưa có lệnh sản xuất nào ở trạng thái nháp.
                </div>
            </t>
            <t t-else="">
                <div class="card mt-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tên lệnh</th>
                                    <th>Sản phẩm</th>
                                    <th class="text-end">Số lượng</th>
                                    <th>Ngày bắt đầu</th>
                                    <th class="text-center">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="productions" t-as="mo"
                                    t-attf-onclick="window.location='/my/productions/#{mo.id}'"
                                    style="cursor: pointer;">
                                    <td class="fw-semibold">
                                        <t t-esc="mo.name"/>
                                    </td>
                                    <td><t t-esc="mo.product_id.display_name or '—'"/></td>
                                    <td class="text-end">
                                        <t t-esc="mo.product_qty"/>
                                        <span class="text-muted ms-1 small">
                                            <t t-esc="mo.product_uom_id.name or ''"/>
                                        </span>
                                    </td>
                                    <td class="text-nowrap">
                                        <t t-if="mo.date_start">
                                            <t t-esc="mo.date_start" t-options="{'widget': 'date'}"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td class="text-center">
                                        <span t-att-class="'badge ' + production_state_color.get(mo.state, 'bg-secondary')">
                                            <t t-esc="production_state_label.get(mo.state, mo.state)"/>
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        </div>
                    </div>
                </div>
            </t>
            </div>
        </t>
    </template>

    <!-- ===================== PRODUCTION DETAIL ===================== -->
    <template id="portal_production_detail" name="Production Detail">
        <t t-call="portal.portal_layout">
            <div class="o_portal_production_detail">

            <!-- Error alert -->
            <div t-if="error" class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                <i class="fa fa-exclamation-triangle me-1"/>
                <strong>Lỗi:</strong> <t t-esc="error"/>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"/>
            </div>

            <!-- Breadcrumb back -->
            <div class="mt-3 mb-3">
                <a href="/my/productions" class="btn btn-sm btn-outline-secondary">
                    <i class="fa fa-arrow-left me-1"/> Danh sách lệnh sản xuất
                </a>
            </div>

            <div class="row g-4">

                <!-- Info card -->
                <div class="col-lg-8">
                    <div class="card h-100">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <h5 class="mb-0">
                                <i class="fa fa-industry me-1 text-muted"/>
                                <t t-esc="production.name"/>
                            </h5>
                            <span t-att-class="'badge fs-6 ' + production_state_color.get(production.state, 'bg-secondary')">
                                <t t-esc="production_state_label.get(production.state, production.state)"/>
                            </span>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-5 text-muted">Sản phẩm</dt>
                                <dd class="col-sm-7">
                                    <t t-esc="production.product_id.display_name or '—'"/>
                                </dd>

                                <dt class="col-sm-5 text-muted">Số lượng SX</dt>
                                <dd class="col-sm-7">
                                    <t t-esc="production.product_qty"/>
                                    <span class="text-muted ms-1">
                                        <t t-esc="production.product_uom_id.name or ''"/>
                                    </span>
                                </dd>

                                <dt class="col-sm-5 text-muted">Người phụ trách</dt>
                                <dd class="col-sm-7">
                                    <t t-esc="production.user_id.name or '—'"/>
                                </dd>

                                <dt class="col-sm-5 text-muted">Ngày bắt đầu</dt>
                                <dd class="col-sm-7">
                                    <t t-esc="fmt_dt(production.date_start)"/>
                                </dd>

                                <dt class="col-sm-5 text-muted">Ngày kết thúc</dt>
                                <dd class="col-sm-7">
                                    <t t-esc="fmt_dt(production.date_finished)"/>
                                </dd>

                                <dt class="col-sm-5 text-muted">Deadline</dt>
                                <dd class="col-sm-7">
                                    <t t-esc="fmt_dt(production.date_deadline)"/>
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>

                <!-- Action panel -->
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0">
                                <i class="fa fa-hand-pointer-o me-1"/>Thao tác
                            </h6>
                        </div>
                        <div class="card-body">
                            <t t-if="production.state == 'draft'">
                                <form t-attf-action="/my/productions/#{production.id}/action" method="POST">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <button name="action" value="confirm" type="submit"
                                            class="btn btn-success w-100">
                                        <i class="fa fa-check me-1"/> Xác nhận lệnh
                                    </button>
                                </form>
                            </t>
                            <t t-else="">
                                <p class="text-muted text-center mb-0 small">
                                    <i class="fa fa-info-circle me-1"/>
                                    Lệnh sản xuất không ở trạng thái nháp.
                                </p>
                            </t>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Components tab -->
            <div class="mt-4">
                <ul class="nav nav-tabs" id="productionTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="components-tab"
                                data-bs-toggle="tab" data-bs-target="#components"
                                type="button" role="tab">
                            <i class="fa fa-list me-1"/>
                            Thành phần
                            <span class="badge bg-light text-dark border ms-1">
                                <t t-esc="len(production.move_raw_ids)"/>
                            </span>
                        </button>
                    </li>
                </ul>
                <div class="tab-content border border-top-0 rounded-bottom" id="productionTabContent">
                    <div class="tab-pane fade show active p-0" id="components" role="tabpanel">
                        <t t-if="not production.move_raw_ids">
                            <p class="text-muted text-center p-4 mb-0">
                                <i class="fa fa-inbox fa-2x d-block mb-2"/>
                                Chưa có thành phần nào.
                            </p>
                        </t>
                        <t t-else="">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Thành phần</th>
                                            <th class="text-end">Cần sử dụng</th>
                                            <th class="text-end">Dự báo tồn</th>
                                            <th>Vị trí nguồn</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="production.move_raw_ids" t-as="move">
                                            <td class="fw-semibold">
                                                <t t-esc="move.product_id.display_name or '—'"/>
                                            </td>
                                            <td class="text-end text-nowrap">
                                                <t t-esc="move.product_uom_qty"/>
                                                <span class="text-muted ms-1 small">
                                                    <t t-esc="move.product_uom.name or ''"/>
                                                </span>
                                            </td>
                                            <td class="text-end text-nowrap">
                                                <t t-if="move.forecast_availability is not False">
                                                    <span t-att-class="'fw-semibold ' + ('text-success' if move.forecast_availability &gt;= 0 else 'text-danger')">
                                                        <t t-esc="'%.2f' % move.forecast_availability"/>
                                                    </span>
                                                    <span class="text-muted ms-1 small">
                                                        <t t-esc="move.product_id.uom_id.name or ''"/>
                                                    </span>
                                                </t>
                                                <t t-else="">—</t>
                                            </td>
                                            <td>
                                                <t t-esc="move.location_id.display_name or '—'"/>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="production.state == 'draft'">
                                                    <a t-attf-href="/my/productions/#{production.id}/move/#{move.id}"
                                                       class="btn btn-sm btn-outline-primary">
                                                        <i class="fa fa-pencil me-1"/> Chi tiết
                                                    </a>
                                                </t>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>
                </div>
            </div>

            </div>
        </t>
    </template>


    <!-- ===================== MOVE RAW DETAIL / EDIT ===================== -->
    <template id="portal_production_move_detail" name="Production Move Detail">
        <t t-call="portal.portal_layout">
            <div class="o_portal_production_detail">

            <!-- Error alert -->
            <div t-if="error" class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                <i class="fa fa-exclamation-triangle me-1"/>
                <strong>Lỗi:</strong> <t t-esc="error"/>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"/>
            </div>

            <!-- Breadcrumb back -->
            <div class="mt-3 mb-3">
                <a t-attf-href="/my/productions/#{production.id}" class="btn btn-sm btn-outline-secondary">
                    <i class="fa fa-arrow-left me-1"/> Quay lại: <t t-esc="production.name"/>
                </a>
            </div>

            <!-- ── Header: product info + qty ── -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">
                        <i class="fa fa-cube me-1 text-muted"/>
                        <t t-esc="move.product_id.display_name or '—'"/>
                    </h5>
                    <span t-att-class="'badge ' + production_state_color.get(production.state, 'bg-secondary')">
                        <t t-esc="production_state_label.get(production.state, production.state)"/>
                    </span>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-sm-5">
                            <dl class="row mb-0 small">
                                <dt class="col-5 text-muted">Lệnh SX</dt>
                                <dd class="col-7"><t t-esc="production.name"/></dd>
                                <dt class="col-5 text-muted">Vị trí nguồn</dt>
                                <dd class="col-7"><t t-esc="move.location_id.display_name or '—'"/></dd>
                                <dt class="col-5 text-muted">Dự báo tồn</dt>
                                <dd class="col-7">
                                    <t t-if="move.forecast_availability is not False">
                                        <span t-att-class="'fw-semibold ' + ('text-success' if move.forecast_availability &gt;= 0 else 'text-danger')">
                                            <t t-esc="'%.2f' % move.forecast_availability"/>
                                        </span>
                                        <span class="text-muted ms-1"><t t-esc="move.product_id.uom_id.name or ''"/></span>
                                    </t>
                                    <t t-else="">—</t>
                                </dd>
                            </dl>
                        </div>
                        <div class="col-sm-7">
                            <form t-attf-action="/my/productions/#{production.id}/move/#{move.id}/save" method="POST"
                                  class="d-flex align-items-end gap-2">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="flex-fill">
                                    <label class="form-label fw-semibold mb-1">
                                        <i class="fa fa-balance-scale me-1"/>Tổng cần dùng
                                    </label>
                                    <div class="input-group">
                                        <input type="number" name="product_uom_qty"
                                               class="form-control"
                                               t-att-value="move.product_uom_qty"
                                               min="0.001" step="0.001" required="required"/>
                                        <span class="input-group-text">
                                            <t t-esc="move.product_uom.name or ''"/>
                                        </span>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save"/>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Move Lines table ── -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h6 class="mb-0">
                        <i class="fa fa-list-ul me-1"/>Thao tác chi tiết
                        <span class="badge bg-light text-dark border ms-1">
                            <t t-esc="len(move.move_line_ids)"/>
                        </span>
                    </h6>
                </div>

                <!-- Inline edit form (shown when ?edit=<line_id>) -->
                <t t-if="edit_line">
                    <div class="card-body border-bottom bg-light">
                        <p class="fw-semibold mb-2 small text-primary">
                            <i class="fa fa-pencil me-1"/>Chỉnh sửa dòng
                        </p>
                        <form t-attf-action="/my/productions/#{production.id}/move/#{move.id}/line/#{edit_line.id}/save"
                              method="POST" class="row g-2 align-items-end">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="col-sm-5">
                                <label class="form-label form-label-sm">Số lô / Serial</label>
                                <input type="text" name="lot_name" class="form-control form-control-sm"
                                       placeholder="VD: LOT001"
                                       t-att-value="edit_line.lot_id.name or edit_line.lot_name or ''"/>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label form-label-sm">Số lượng</label>
                                <div class="input-group input-group-sm">
                                    <input type="number" name="quantity" class="form-control"
                                           t-att-value="edit_line.quantity"
                                           min="0.001" step="0.001" required="required"/>
                                    <span class="input-group-text">
                                        <t t-esc="move.product_uom.name or ''"/>
                                    </span>
                                </div>
                            </div>
                            <div class="col-sm-3 d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-primary flex-fill">
                                    <i class="fa fa-save me-1"/>Lưu
                                </button>
                                <a t-attf-href="/my/productions/#{production.id}/move/#{move.id}"
                                   class="btn btn-sm btn-outline-secondary flex-fill">
                                    <i class="fa fa-times"/>
                                </a>
                            </div>
                        </form>
                    </div>
                </t>

                <!-- Lines table -->
                <div class="table-responsive">
                    <t t-if="not move.move_line_ids">
                        <p class="text-muted text-center p-4 mb-0">
                            <i class="fa fa-inbox fa-2x d-block mb-2"/>
                            Chưa có dòng nào. Thêm dòng bên dưới.
                        </p>
                    </t>
                    <t t-else="">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Số lô / Serial</th>
                                    <th class="text-end">Số lượng</th>
                                    <th>Đơn vị</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="move.move_line_ids" t-as="line">
                                    <td>
                                        <t t-esc="line.lot_id.name or line.lot_name or '—'"/>
                                    </td>
                                    <td class="text-end fw-semibold">
                                        <t t-esc="line.quantity"/>
                                    </td>
                                    <td class="text-muted small">
                                        <t t-esc="line.product_uom_id.name or ''"/>
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <a t-attf-href="/my/productions/#{production.id}/move/#{move.id}?edit=#{line.id}"
                                           class="btn btn-sm btn-outline-secondary me-1">
                                            <i class="fa fa-pencil"/>
                                        </a>
                                        <form t-attf-action="/my/productions/#{production.id}/move/#{move.id}/line/#{line.id}/delete"
                                              method="POST" class="d-inline"
                                              onsubmit="return confirm('Xóa dòng này?')">
                                            <input type="hidden" name="csrf_token"
                                                   t-att-value="request.csrf_token()"/>
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="fa fa-trash"/>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                </div>

                <!-- Add new line form -->
                <div class="card-footer">

                    <!-- PRIMARY: Chọn từ tồn kho (stock.quant) -->
                    <t t-if="available_quants">
<!--                        <p class="fw-semibold mb-2 small text-success">-->
<!--                            <i class="fa fa-plus me-1"/>Thêm từ tồn kho-->
<!--                        </p>-->
                        <form t-attf-action="/my/productions/#{production.id}/move/#{move.id}/add-line"
                              method="POST" class="row g-2 align-items-end mb-3">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="col-sm-9">
                                <label class="form-label form-label-sm">Chọn lô hàng / vị trí</label>
                                <select name="quant_id" class="form-select form-select-sm" required="required">
                                    <option value="">-- Chọn lô hàng --</option>
                                    <t t-foreach="available_quants" t-as="q">
                                        <option t-att-value="q.id">
                                            <t t-if="q.lot_id">
                                                <t t-esc="q.lot_id.name"/> —
                                            </t>
                                            <t t-esc="q.location_id.display_name"/>
                                            (<t t-esc="'%.2f' % q.available_quantity"/>
                                            <t t-esc="move.product_uom.name or ''"/> KD)
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-sm-3">
                                <button type="submit" class="btn btn-sm btn-success w-100">
                                    <i class="fa fa-plus me-1"/>Thêm
                                </button>
                            </div>
                        </form>
                        <hr class="my-2"/>
                    </t>

                    <!-- FALLBACK: Nhập thủ công -->
                    <p class="fw-semibold mb-2 small text-muted">
                        <i class="fa fa-pencil me-1"/>Nhập thủ công
                    </p>
                    <form t-attf-action="/my/productions/#{production.id}/move/#{move.id}/add-line"
                          method="POST" class="row g-2 align-items-end">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="col-sm-5">
                            <label class="form-label form-label-sm">Số lô / Serial</label>
                            <input type="text" name="lot_name" class="form-control form-control-sm"
                                   placeholder="VD: LOT001 (để trống nếu không theo dõi lô)"/>
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label form-label-sm">Số lượng</label>
                            <div class="input-group input-group-sm">
                                <input type="number" name="quantity" class="form-control"
                                       placeholder="0" min="0.001" step="0.001" required="required"/>
                                <span class="input-group-text">
                                    <t t-esc="move.product_uom.name or ''"/>
                                </span>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <button type="submit" class="btn btn-sm btn-outline-success w-100">
                                <i class="fa fa-plus me-1"/>Thêm
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            </div>
        </t>
    </template>

</odoo>
