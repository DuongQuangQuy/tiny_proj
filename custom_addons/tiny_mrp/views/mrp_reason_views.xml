<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mrp_reason_form" model="ir.ui.view">
        <field name="name">mrp.reason.form</field>
        <field name="model">mrp.reason</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Lý do">
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="mrp_reason_list" model="ir.ui.view">
        <field name="name">mrp.reason.list</field>
        <field name="model">mrp.reason</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="mrp_reason_search" model="ir.ui.view">
        <field name="name">mrp.reason.search</field>
        <field name="model">mrp.reason</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_mrp_reason" model="ir.actions.act_window">
        <field name="name">Lý do</field>
        <field name="res_model">mrp.reason</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
