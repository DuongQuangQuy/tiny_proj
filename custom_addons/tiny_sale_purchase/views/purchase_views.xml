<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Purchase Order Form View -->
    <record id="view_purchase_order_form_inherit_tiny_sale_purchase" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.tiny.sale.purchase</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="sale_multi_origin" invisible="not sale_multi_origin"/>
            </xpath>
        </field>
    </record>
</odoo>
